  <diagram name="Five Songs Forward Architecture" id="fsf-arch-mvp">
    <mxGraphModel dx="1200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Five Songs Forward — System Architecture (MVP, public, no login)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="650" height="30" as="geometry" />
        </mxCell>

        <mxCell id="label-user" value="User" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-frontend" value="&lt;b&gt;Web app frontend (public, no login)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Drop 3–5 seed songs, view 25 recommendations with per-track &quot;Open on Spotify&quot; links&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="100" y="95" width="650" height="70" as="geometry" />
        </mxCell>

        <mxCell id="label-backend" value="Backend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-backend" value="&lt;b&gt;Lightweight backend service&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Authenticates as the app (Client Credentials), orchestrates all API calls, hides secrets,&lt;br&gt;enforces per-IP rate limits + caches results by seed-set hash&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3C3489;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="100" y="225" width="650" height="80" as="geometry" />
        </mxCell>

        <mxCell id="label-datafetch" value="Data fetch" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-spotify" value="&lt;b&gt;Spotify Web API&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Client Credentials token,&lt;br&gt;seed resolution, artist metadata,&lt;br&gt;catalogue search (LLM-driven queries)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#085041;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="100" y="365" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-llm-primary" value="&lt;b&gt;Primary LLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Tries first (e.g. Groq)&lt;br&gt;One call: seed interpretation +&lt;br&gt;suggested artists/keywords&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;strokeColor=#993C1D;fontColor=#712B13;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="400" y="365" width="170" height="100" as="geometry" />
        </mxCell>
        <mxCell id="node-llm-secondary" value="&lt;b&gt;Secondary LLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Auto-fallback (e.g. Gemini)&lt;br&gt;Same prompt, same output&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBEAF0;strokeColor=#993556;fontColor=#72243E;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="590" y="365" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="arr-failover" value="if limit hit" style="endArrow=classic;html=1;rounded=0;strokeColor=#993C1D;strokeWidth=1.5;fontSize=10;fontColor=#993C1D;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="node-llm-primary" target="node-llm-secondary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="arr-1" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-frontend" target="node-backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-2a" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.2;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-backend" target="node-spotify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-2b" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-backend" target="node-llm-primary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="label-matching" value="Matching" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="500" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-matching" value="&lt;b&gt;Seed-driven retrieval and ranking&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Builds candidate pool from LLM-suggested artist names and keywords via /search,&lt;br&gt;dedupes, applies diversity pass, picks final 25&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3C3489;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="100" y="525" width="650" height="90" as="geometry" />
        </mxCell>

        <mxCell id="arr-3a" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-spotify" target="node-matching">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-3b" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.6;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-llm-primary" target="node-matching">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-3c" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-llm-secondary" target="node-matching">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="label-fallback" value="If both fail" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="650" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-fallback" value="&lt;b&gt;If both LLMs fail → show &quot;engine temporarily unavailable&quot; error (no artist-graph fallback exists)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=12;verticalAlign=middle;align=center;arcSize=15;dashed=1" vertex="1" parent="1">
          <mxGeometry x="100" y="675" width="650" height="50" as="geometry" />
        </mxCell>
        <mxCell id="arr-4" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-matching" target="node-fallback">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="label-output" value="Output" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="760" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="node-output" value="&lt;b&gt;25 tracks rendered in our own UI&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;Cover art, artist, track name, 30-second preview player (where available),&lt;br&gt;and an &quot;Open on Spotify&quot; button per track for full playback&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;verticalAlign=middle;align=center;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="100" y="785" width="650" height="80" as="geometry" />
        </mxCell>
        <mxCell id="arr-5" style="endArrow=classic;html=1;rounded=0;strokeColor=#5F5E5A;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="node-fallback" target="node-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B4B2A9;strokeWidth=1;arcSize=10" vertex="1" parent="1">
          <mxGeometry x="100" y="900" width="650" height="230" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="115" y="910" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-grey" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1EFE8;strokeColor=#5F5E5A;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="120" y="940" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-grey-t" value="Grey — user-facing web app (public, no login)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="160" y="940" width="270" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-purple" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="120" y="970" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-purple-t" value="Purple — our own backend and matching logic" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="160" y="970" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-teal" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#0F6E56;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="120" y="1000" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-teal-t" value="Teal — Spotify Web API (search + metadata, Client Credentials)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="160" y="1000" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-coral" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;strokeColor=#993C1D;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="420" y="940" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-coral-t" value="Coral — primary free LLM API" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="460" y="940" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-pink" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBEAF0;strokeColor=#993556;arcSize=15" vertex="1" parent="1">
          <mxGeometry x="420" y="970" width="30" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-pink-t" value="Pink — secondary LLM (automatic failover)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="460" y="970" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-note" value="Flow is top-to-bottom. Public site — no user login, no allowlist. Backend authenticates as the app via Client Credentials and fans out to Spotify + primary LLM in parallel. One LLM call per generation returns direction + adjacent artist names + search keywords. Backend runs those through /search to build the candidate pool. If primary LLM is rate-limited, the same call retries on the secondary automatically. If both LLMs fail, there is no artist-graph fallback (those Spotify endpoints are restricted for new apps) — the app shows a clean error. Final 25 tracks are shown in our own UI with per-track preview + &quot;Open on Spotify&quot; links." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;fontColor=#5F5E5A" vertex="1" parent="1">
          <mxGeometry x="115" y="1030" width="620" height="90" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
